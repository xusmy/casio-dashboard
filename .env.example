# ── CALENDARIO ──────────────────────────────────────────────────────────────
# Opción A: Calendarios ICS (Google Calendar, iCloud, Outlook, etc.)
# Obtené la URL en: Google Calendar → Configuración → [tu calendario] → Integrar → "Dirección secreta en formato iCal"

CAL_NAME_1=Work
CAL_ICS_1=https://calendar.google.com/calendar/ical/YOUR_EMAIL/private-TOKEN/basic.ics

CAL_NAME_2=Personal
CAL_ICS_2=https://calendar.google.com/calendar/ical/YOUR_EMAIL/public/basic.ics

# Opción B: Google Apps Script (recomendado para cuentas Google Workspace donde los títulos aparecen como "BUSY")
# Ver README para instrucciones de configuración.
CAL_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── SEGURIDAD ────────────────────────────────────────────────────────────────
# Contraseña para proteger el calendario (recomendado si tu URL es pública)
# Si lo definís, el dashboard la pedirá una vez y la recordará en el dispositivo.
DASH_SECRET=tu-contraseña-secreta

# ── UBICACIÓN (para el clima) ────────────────────────────────────────────────
# La ubicación se configura directamente en index.html (variables LAT y LON)
# Por defecto: Buenos Aires, Argentina (-34.6037, -58.3816)
